{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "stock-ui/dist" }
    },
    {
      "src": "backend/api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "backend/api.py" },
    { "src": "/predict/(.*)", "dest": "backend/api.py" },
    { "src": "/chart/(.*)", "dest": "backend/api.py" },
    { "src": "/portfolio", "dest": "backend/api.py" },
    { "src": "/news/(.*)", "dest": "backend/api.py" },
    { "src": "/fundamentals/(.*)", "dest": "backend/api.py" },
    {"methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]},

    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
