{
  "version": 2,
  "builds": [
    {
      "src": "stock-ui/package.json",
      "use": "@vercel/static-build",
      "config": {"distDir": "dist"}
    },
    {
      "src": "api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "api.py" },
    { "src": "/predict/(.*)", "dest": "api.py" },
    { "src": "/chart/(.*)", "dest": "api.py" },
    { "src": "/portfolio", "dest": "api.py" },
    { "src": "/news/(.*)", "dest": "api.py" },
    { "src": "/fundamentals/(.*)", "dest": "api.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
