{
  "version": 2,
  "buildCommand": "cd stock-ui && npm install && npm run build",
  "outputDirectory": "stock-ui/dist",
  "framework": "vite",
  "installCommand": "cd stock-ui && npm install",
  "devCommand": "cd stock-ui && npm run dev",
  "regions": ["bom1"],
  "functions": {
    "api.py": {
      "runtime": "python3.9",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api.py" },
    { "source": "/(.*)", "destination": "/stock-ui/dist/index.html" }
  ]
}
