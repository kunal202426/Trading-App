{
  "version": 2,
  "buildCommand": "npm --prefix stock-ui run build",
  "outputDirectory": "stock-ui/dist",
  "rewrites": [
    { "source": "/health",             "destination": "/api/index" },
    { "source": "/predict/:path*",     "destination": "/api/index" },
    { "source": "/chart/:path*",       "destination": "/api/index" },
    { "source": "/portfolio",          "destination": "/api/index" },
    { "source": "/news/:path*",        "destination": "/api/index" },
    { "source": "/fundamentals/:path*","destination": "/api/index" }
  ]
}
