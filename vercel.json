{
  "version": 2,
  "builds": [
    {
      "src": "stock-ui/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api.py" },
    { "src": "/(.*)", "dest": "/stock-ui/dist/index.html" }
  ]
}
